# Model: the agent calls Anthropic directly.
ANTHROPIC_API_KEY=

# LangSmith: a WORKSPACE-scoped service key for the workspace that holds the Hub repos.
# https://docs.langchain.com/langsmith/create-account-api-key
LANGSMITH_API_KEY=

# Tracing.
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=demo-crm-agent
